---

---

<div
    id="cart-drawer"
    class="fixed inset-0 z-[100] pointer-events-none invisible overflow-hidden"
>
    <div
        id="cart-backdrop"
        class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/40 to-transparent backdrop-blur-md opacity-0 transition-opacity duration-700"
    >
    </div>

    <div
        id="cart-panel"
        class="absolute top-0 right-0 w-full max-w-md h-full translate-x-full transition-transform duration-700 ease-expo pointer-events-auto cart-panel-glass rounded-none sm:rounded-l-2xl overflow-hidden pt-[env(safe-area-inset-top)] pb-[env(safe-area-inset-bottom)]"
    >
        <div class="absolute inset-0 bg-gradient-to-l from-[#000d12]/95 via-[#000d12]/90 to-[#000d12]/70 backdrop-blur-xl">
        </div>
        <div
            class="absolute top-0 right-0 w-full h-full pointer-events-none overflow-hidden"
        >
            <div
                class="absolute top-[-10%] right-[-10%] w-[80%] h-[50%] bg-cyan-400/12 blur-[120px] rounded-full"
            >
            </div>
            <div
                class="absolute bottom-[10%] left-[-20%] w-[70%] h-[50%] bg-blue-300/6 blur-[100px] rounded-full"
            >
            </div>
            <div
                class="absolute top-[40%] left-[-10%] w-[40%] h-[40%] bg-cyan-600/5 blur-[80px] rounded-full"
            >
            </div>
        </div>

        <div class="relative z-10 h-full flex flex-col p-4 sm:p-8 md:p-12 overflow-y-auto overscroll-contain">
            <div class="flex justify-between items-center mb-10 sm:mb-16">
                <div class="space-y-2">
                    <div class="flex items-center gap-3">
                        <span class="w-6 h-[2px] rounded-full bg-cyan-600/40"></span>
                        <span
                            class="text-cyan-500/50 text-xs tracking-[0.08em] font-light"
                            >Selection</span
                        >
                    </div>
                    <h2 class="text-white text-3xl font-light tracking-[0.04em]">
                        Bag
                    </h2>
                </div>
                <button id="close-cart" class="group p-3 -m-2 touch-manipulation min-h-[44px] min-w-[44px] flex items-center justify-center">
                    <span
                        class="text-white/40 group-hover:text-white transition-colors duration-500 text-sm tracking-wide font-light"
                        >Close</span
                    >
                </button>
            </div>

            <div id="cart-empty-state" class="flex-grow flex flex-col items-center justify-center text-center space-y-8">
                <div class="w-16 h-[2px] rounded-full bg-white/[0.06]"></div>
                <div class="space-y-4">
                    <p class="text-white/20 text-sm tracking-[0.04em] font-light">
                        Bag is currently empty
                    </p>
                    <div class="flex justify-center">
                        <a
                            href="/#shop"
                            id="continue-shopping"
                            class="text-cyan-500/40 hover:text-cyan-400 transition-all duration-500 text-sm tracking-[0.04em] font-light border-b border-cyan-500/10 pb-1 hover:border-cyan-400/30"
                            >Begin exploring</a
                        >
                    </div>
                </div>
                <div class="w-16 h-[2px] rounded-full bg-white/[0.06]"></div>
            </div>

            <div id="cart-items-container" class="flex-grow overflow-y-auto hidden">
            </div>

            <div id="cart-footer" class="mt-auto space-y-8 pt-12 border-t border-white/[0.06]">
                <div class="flex justify-between items-end">
                    <span class="text-white/40 text-sm tracking-wide font-light">
                        Subtotal
                    </span>
                    <span id="cart-subtotal" class="text-white text-xl font-light tracking-widest">
                        0.00 DKK
                    </span>
                </div>
                <div class="space-y-4">
                    <a
                        id="cart-checkout-btn"
                        href="#"
                        class="hidden w-full py-6 border border-white/20 rounded-2xl text-white text-sm tracking-[0.04em] font-light relative group overflow-hidden transition-all duration-700 hover:border-cyan-400/40 flex items-center justify-center"
                    >
                        <span class="relative z-10 font-light">Checkout</span>
                        <div class="absolute bottom-0 left-0 w-0 h-[1px] bg-cyan-400/60 group-hover:w-full transition-all duration-700"></div>
                    </a>
                    <button
                        id="cart-checkout-disabled"
                        type="button"
                        class="w-full py-6 border border-white/10 rounded-2xl text-white/40 text-sm tracking-[0.04em] relative overflow-hidden cursor-not-allowed opacity-60 flex items-center justify-center"
                    >
                        <span class="relative z-10 font-light italic">Selection required</span>
                    </button>
                    <p class="text-xs text-white/20 tracking-[0.04em] font-light text-center">
                        Shipping and taxes calculated at checkout
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    import gsap from "gsap";
    import { getCart } from "../lib/cart-client";
    import { removeCartLine, updateCartLine } from "../lib/shopify";
    import { getCartId, setCartId, dispatchCartUpdated } from "../lib/cart-store";

    const cartBtn = document.querySelector('[aria-label="Kurv"]');
    const closeBtn = document.getElementById("close-cart");
    const backdrop = document.getElementById("cart-backdrop");
    const drawer = document.getElementById("cart-drawer");
    const panel = document.getElementById("cart-panel");
    const continueBtn = document.getElementById("continue-shopping");
    const emptyState = document.getElementById("cart-empty-state");
    const itemsContainer = document.getElementById("cart-items-container");
    const subtotalEl = document.getElementById("cart-subtotal");
    const checkoutBtn = document.getElementById("cart-checkout-btn");
    const checkoutDisabled = document.getElementById("cart-checkout-disabled");

    const openCart = () => {
        if (!drawer || !panel || !backdrop) return;
        drawer.classList.remove("invisible");
        drawer.classList.add("pointer-events-auto");
        gsap.to(backdrop, { opacity: 1, duration: 1, ease: "power2.out" });
        gsap.to(panel, { x: 0, duration: 1.4, ease: "expo.out", overwrite: true });
        renderCart();
    };

    const closeCart = () => {
        if (!drawer || !panel || !backdrop) return;
        gsap.to(panel, { x: "100%", duration: 1, ease: "power2.inOut", overwrite: true });
        gsap.to(backdrop, {
            opacity: 0,
            duration: 0.8,
            onComplete: () => {
                drawer.classList.add("invisible");
                drawer.classList.remove("pointer-events-auto");
            },
        });
    };

    function renderCartItem(line: {
        id: string;
        quantity: number;
        merchandise: {
            id: string;
            title: string;
            product: { title: string; handle: string };
            price: { amount: string; currencyCode: string };
            image?: { url: string };
        };
    }) {
        const div = document.createElement("div");
        div.className = "flex gap-4 py-6 border-b border-white/[0.06]";
        div.innerHTML = `
            <a href="/product/${line.merchandise.product.handle}" class="shrink-0 w-20 h-24 rounded-xl overflow-hidden bg-[#051117]">
                <img src="${line.merchandise.image?.url ?? "/collectionimg/wfront.jpg"}" alt="" class="w-full h-full object-cover" />
            </a>
            <div class="flex-grow min-w-0">
                <p class="text-white text-sm font-light truncate">${line.merchandise.product.title}</p>
                <p class="text-white/50 text-xs font-light">${line.merchandise.title} · ${line.merchandise.price.amount} ${line.merchandise.price.currencyCode}</p>
                <div class="flex items-center gap-2 mt-2">
                    <button type="button" class="cart-line-qty text-white/60 text-xs hover:text-white" data-line-id="${line.id}" data-qty="${line.quantity - 1}">−</button>
                    <span class="text-white/80 text-xs">${line.quantity}</span>
                    <button type="button" class="cart-line-qty text-white/60 text-xs hover:text-white" data-line-id="${line.id}" data-qty="${line.quantity + 1}">+</button>
                    <button type="button" class="cart-line-remove ml-4 text-white/40 text-xs hover:text-red-400" data-line-id="${line.id}">Fjern</button>
                </div>
            </div>
        `;
        return div;
    }

    async function renderCart() {
        let cart;
        try {
            cart = await getCart();
        } catch {
            cart = null;
        }
        const lines = cart?.lines?.edges?.map((e) => e.node) ?? [];

        const totalQty = lines.reduce((sum, line) => sum + (line.quantity ?? 0), 0);

        if (emptyState) emptyState.classList.toggle("hidden", lines.length > 0);
        if (itemsContainer) itemsContainer.classList.toggle("hidden", lines.length === 0);

        if (lines.length === 0) {
            if (subtotalEl) subtotalEl.textContent = "0.00 DKK";
            if (checkoutBtn) checkoutBtn.classList.add("hidden");
            if (checkoutDisabled) checkoutDisabled.classList.remove("hidden");
            dispatchCartUpdated(0);
            return;
        }

        itemsContainer.innerHTML = "";
        lines.forEach((line) => {
            itemsContainer.appendChild(renderCartItem(line));
        });

        const subtotal = cart?.cost?.subtotalAmount;
        if (subtotalEl && subtotal) {
            subtotalEl.textContent = `${parseFloat(subtotal.amount).toFixed(2)} ${subtotal.currencyCode}`;
        }
        if (checkoutBtn) {
            checkoutBtn.href = cart?.checkoutUrl ?? "#";
            checkoutBtn.classList.remove("hidden");
        }
        if (checkoutDisabled) checkoutDisabled.classList.add("hidden");
        dispatchCartUpdated(totalQty);

        itemsContainer.querySelectorAll(".cart-line-qty").forEach((btn) => {
            btn.addEventListener("click", async (e) => {
                const target = e.currentTarget as HTMLButtonElement;
                const lineId = target.dataset.lineId;
                const qty = parseInt(target.dataset.qty ?? "1", 10);
                const cartId = getCartId();
                if (!lineId || !cartId) return;
                try {
                    if (qty < 1) {
                        await removeCartLine(cartId, lineId);
                    } else {
                        await updateCartLine(cartId, lineId, qty);
                    }
                    const cart = await getCart();
                    if (cart && cart.lines.edges.length === 0) setCartId(null);
                    renderCart();
                } catch (err) {
                    console.error(err);
                }
            });
        });
        itemsContainer.querySelectorAll(".cart-line-remove").forEach((btn) => {
            btn.addEventListener("click", async () => {
                const lineId = (btn as HTMLButtonElement).dataset.lineId;
                const cartId = getCartId();
                if (!lineId || !cartId) return;
                try {
                    await removeCartLine(cartId, lineId);
                    const cart = await getCart();
                    if (cart && cart.lines.edges.length === 0) {
                        setCartId(null);
                    }
                    renderCart();
                } catch (err) {
                    console.error(err);
                }
            });
        });
    }

    cartBtn?.addEventListener("click", openCart);
    closeBtn?.addEventListener("click", closeCart);
    backdrop?.addEventListener("click", closeCart);
    continueBtn?.addEventListener("click", closeCart);

    function initCartBadge() {
        getCart()
            .then((cart) => {
                const count = cart?.lines?.edges?.length ?? 0;
                dispatchCartUpdated(count);
            })
            .catch(() => dispatchCartUpdated(0));
    }
    if ("requestIdleCallback" in window) {
        requestIdleCallback(() => initCartBadge(), { timeout: 3000 });
    } else {
        setTimeout(initCartBadge, 500);
    }

    (window as any).openCart = openCart;
</script>

<style>
    .ease-expo {
        transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    }
    .cart-panel-glass {
        box-shadow: -20px 0 60px -20px rgba(0, 0, 0, 0.4);
    }
</style>
