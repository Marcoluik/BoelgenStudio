---
import { products } from "./products.astro";
---

{/* Spacer to let hero be visible before collection scrolls up */}
<div class="h-screen pointer-events-none"></div>

<section
  id="shop"
  class="collection-section relative z-10 pt-48 sm:pt-64 pb-24 sm:pb-32 md:pt-96 md:pb-64 overflow-hidden bg-transparent"
>
  <div
    class="archive-bg fixed inset-0 pointer-events-none opacity-0 z-0 bg-[#000d12] backdrop-blur-xl"
  >
    <div
      class="absolute top-[-10%] left-[20%] w-[60%] h-[60%] bg-cyan-400/10 blur-[150px] rounded-full"
    >
    </div>
    <div
      class="absolute bottom-[20%] right-[10%] w-[50%] h-[50%] bg-blue-300/5 blur-[120px] rounded-full"
    >
    </div>
    <div
      class="absolute top-[40%] left-[-10%] w-[40%] h-[40%] bg-cyan-600/5 blur-[100px] rounded-full"
    >
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 relative z-10">
    {/* Section Title - Rethought: readable hierarchy, organic feel */}
    <div class="archive-header mb-20 sm:mb-32 md:mb-72 overflow-hidden">
      <div class="flex flex-col md:flex-row md:items-end md:gap-12 gap-6 sm:gap-8">
        <div>
          <h2
            class="text-white/90 text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-light tracking-[-0.02em] leading-[1.1]"
          >
            Collection
          </h2>
          <p class="text-cyan-200/50 text-base md:text-lg mt-4 font-light tracking-[0.02em]">
            Permanent / 01
          </p>
        </div>
        <div class="md:pb-1">
          <svg class="w-20 md:w-32 h-4 text-cyan-400/25" viewBox="0 0 128 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 8 Q32 0 64 8 T128 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="space-y-32 sm:space-y-64 md:space-y-[40rem]">
      {
        products.map((product, index) => (
          <div
            class={`product-row flex flex-col ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"} items-center gap-10 sm:gap-16 md:gap-32`}
          >
            {/* Main Visual Container */}
            <div class="w-full md:w-3/5 relative group">
              <a
                href={`/product/${product.id}`}
                class="block relative overflow-hidden rounded-2xl bg-[#051117] touch-manipulation active:scale-[0.98] transition-transform"
              >
                <div class="aspect-[4/5] md:aspect-[16/10] overflow-hidden">
                  {/* Main Image */}
                  <img
                    src={product.mainImage}
                    alt={product.name}
                    class="absolute inset-0 w-full h-full object-cover transition-all duration-[2.5s] ease-out scale-105 group-hover:scale-110 opacity-100 group-hover:opacity-0"
                  />
                  {/* Back Image (Revealed on hover) */}
                  <img
                    src={product.backImage}
                    alt={`${product.name} alternate view`}
                    class="absolute inset-0 w-full h-full object-cover transition-all duration-[2.5s] ease-out scale-110 group-hover:scale-100 opacity-0 group-hover:opacity-100"
                  />

                  {/* The Dark Overlay for depth - Cyan Tinted */}
                  <div class="absolute inset-0 bg-gradient-to-t from-[#000d12]/80 via-transparent to-transparent opacity-60" />
                </div>

                {/* Hover Interaction Overlay - subtle tint only, no blur so image stays visible */}
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-1000 bg-[#000d12]/20">
                  <div class="px-10 py-4 border border-cyan-400/25 rounded-full text-white text-sm tracking-[0.06em] font-light bg-[#001c25]/80 backdrop-blur-sm shadow-lg shadow-black/30">
                    Dive
                  </div>
                </div>
              </a>

              {/* Floating Index Number - Cinematic Detail */}
              <div
                class={`absolute top-0 ${index % 2 === 0 ? "left-0 sm:-left-8 md:-left-16" : "right-0 sm:-right-8 md:-right-16"} -translate-y-1/2 overflow-hidden pointer-events-none`}
              >
                <span class="text-cyan-100/[0.08] text-6xl sm:text-8xl md:text-9xl font-light tracking-tight">
                  0{index + 1}
                </span>
              </div>

              {/* Overlapping Piece Name */}
              <div
                class={`hidden lg:block absolute bottom-12 ${index % 2 === 0 ? "-right-24" : "-left-24"} mix-blend-screen pointer-events-none transition-transform duration-1000 group-hover:translate-y-[-10px]`}
              >
                <h3 class="text-cyan-50/70 text-7xl xl:text-8xl font-light tracking-tight leading-none">
                  {product.name.split(" ")[1]}
                </h3>
              </div>
            </div>

            {/* Product Description Side */}
            <div class="w-full md:w-2/5 space-y-10">
              <div class="space-y-6">
                <div class="flex items-center gap-4">
                  <span class="w-6 h-[2px] rounded-full bg-cyan-600/40" />
                  <span class="text-cyan-400/50 text-xs tracking-[0.1em] font-light">
                    Selection {index + 1}
                  </span>
                </div>
                <h4 class="text-white text-3xl sm:text-4xl lg:text-6xl font-light tracking-[0.02em] leading-tight">
                  {product.subName}
                </h4>
                <div class="w-12 h-[2px] rounded-full bg-cyan-500/15" />
              </div>

              <p class="text-cyan-100/50 text-base leading-relaxed tracking-wide font-light max-w-sm">
                {product.description}
              </p>

              <div class="flex items-baseline gap-8">
                <span class="text-white text-2xl font-light tracking-wide">
                  {product.price}
                </span>
                <a
                  href={`/product/${product.id}`}
                  class="group/link flex items-center gap-4 text-cyan-400/40 hover:text-cyan-100 transition-colors duration-500 text-sm tracking-[0.04em] font-light py-2 -my-2 touch-manipulation"
                >
                  Details
                  <div class="w-10 h-[2px] rounded-full bg-cyan-500/10 group-hover/link:bg-cyan-400/50 group-hover/link:w-16 transition-all duration-700" />
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-64"></div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.to(".archive-bg", {
    scrollTrigger: {
      trigger: "body",
      start: "top top",
      end: "18% top",
      scrub: true,
    },
    opacity: 1,
  });

  gsap.from(".archive-header > *", {
    scrollTrigger: {
      trigger: ".archive-header",
      start: "top 90%",
    },
    y: 50,
    opacity: 0,
    duration: 2,
    stagger: 0.2,
    ease: "expo.out",
  });

  const rows = document.querySelectorAll(".product-row");
  rows.forEach((row, i) => {
    const visual = row.querySelector(".w-full.md\\:w-3\\/5");
    const content = row.querySelector(".w-full.md\\:w-2\\/5");

    gsap.from(visual, {
      scrollTrigger: {
        trigger: row,
        start: "top 80%",
      },
      opacity: 0,
      duration: 2.5,
      ease: "expo.out",
    });

    gsap.from(content, {
      scrollTrigger: {
        trigger: row,
        start: "top 70%",
      },
      opacity: 0,
      duration: 2.5,
      delay: 0.4,
      ease: "expo.out",
    });
  });
</script>

<style>
  .product-row {
    will-change: transform, opacity;
  }
</style>
