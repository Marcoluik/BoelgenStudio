---
import type { UnifiedProduct } from "../lib/product-utils";

interface Props {
  products: UnifiedProduct[];
}

const { products } = Astro.props;
---

{/* Spacer to let hero be visible before collection scrolls up */}
<div class="h-screen pointer-events-none"></div>

<section
  id="shop"
  class="collection-section relative z-10 pt-20 sm:pt-40 pb-10 sm:pb-24 md:pt-56 md:pb-40 overflow-hidden bg-transparent"
>
  <div
    class="archive-bg fixed inset-0 pointer-events-none opacity-0 z-0 bg-[#000d12] backdrop-blur-xl"
  >
    <div
      class="absolute top-[-10%] left-[20%] w-[60%] h-[60%] bg-cyan-400/18 blur-[120px] rounded-full"
    >
    </div>
    <div
      class="absolute bottom-[20%] right-[10%] w-[50%] h-[50%] bg-blue-300/10 blur-[100px] rounded-full"
    >
    </div>
    <div
      class="absolute top-[40%] left-[-10%] w-[40%] h-[40%] bg-cyan-600/8 blur-[80px] rounded-full"
    >
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 relative z-10 max-w-7xl">
    {/* Section Title - Rethought: readable hierarchy, organic feel */}
    <div class="archive-header mb-8 sm:mb-20 md:mb-40 overflow-hidden">
      <div class="flex flex-col md:flex-row md:items-end md:gap-12 gap-6 sm:gap-8">
        <div class="min-w-0">
          <h2
            class="text-white/90 text-3xl sm:text-5xl md:text-7xl lg:text-8xl font-light tracking-[-0.02em] leading-[1.1]"
          >
            Kollektion
          </h2>
          <p class="text-cyan-200/50 text-sm sm:text-base md:text-lg mt-3 sm:mt-4 font-light tracking-[0.02em]">
            Permanent / 01
          </p>
        </div>
        <div class="md:pb-1">
          <svg class="w-20 md:w-32 h-4 text-cyan-400/25" viewBox="0 0 128 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 8 Q32 0 64 8 T128 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
      </div>
    </div>

    <div class="space-y-14 sm:space-y-32 md:space-y-64">
      {
        products.map((product, index) => (
          <div
            data-product-card
            class={`product-row flex flex-col ${index % 2 === 0 ? "md:flex-row" : "md:flex-row-reverse"} items-center gap-8 sm:gap-16 md:gap-32`}
          >
            {/* Main Visual Container */}
            <div class="w-full md:w-3/5 max-w-2xl mx-auto md:mx-0 relative isolate group">
              <a
                data-product-card-link
                href={`/product/${product.handle}`}
                aria-label={`Åbn ${product.name}`}
                class="block relative z-10 overflow-hidden rounded-2xl bg-[#051117] touch-manipulation active:scale-[0.98] transition-transform min-h-[44px]"
              >
                <div class="aspect-[4/5] md:aspect-[16/10] overflow-hidden">
                  {/* Main Image (front) */}
                  <img
                    src={product.mainImage}
                    alt={product.name}
                    class="absolute inset-0 w-full h-full object-cover transition-all duration-500 ease-out scale-105 group-hover:scale-110 opacity-100 group-hover:opacity-0"
                  />
                  {/* Back Image (Revealed on hover) */}
                  <img
                    src={product.backImage}
                    alt={`${product.name} bagside`}
                    class="absolute inset-0 w-full h-full object-cover transition-all duration-500 ease-out scale-110 group-hover:scale-100 opacity-0 group-hover:opacity-100"
                  />

                  {/* The Dark Overlay for depth - Cyan Tinted */}
                  <div class="absolute inset-0 bg-gradient-to-t from-[#000d12]/80 via-transparent to-transparent opacity-60" />
                </div>
              </a>

              {/* Floating Index Number - Cinematic Detail */}
              <div
                class={`absolute top-0 ${index % 2 === 0 ? "left-0 sm:-left-8 md:-left-16" : "right-0 sm:-right-8 md:-right-16"} -translate-y-1/2 overflow-hidden pointer-events-none select-none z-20`}
              >
                <span class="text-cyan-100/[0.08] text-5xl sm:text-8xl md:text-9xl font-light tracking-tight">
                  0{index + 1}
                </span>
              </div>

              {/* Overlapping Piece Name */}
              <div
                class={`hidden lg:block absolute bottom-12 ${index % 2 === 0 ? "-right-24" : "-left-24"} mix-blend-screen pointer-events-none transition-transform duration-400 group-hover:translate-y-[-10px] z-20`}
              >
                <h3 class="text-cyan-50/70 text-7xl xl:text-8xl font-light tracking-tight leading-none">
                  {product.name.split(" ")[1]}
                </h3>
              </div>
            </div>

            {/* Product Description Side */}
              <div class="w-full md:w-2/5 space-y-6 sm:space-y-10 min-w-0 relative z-10">
              <div class="space-y-6">
                <div class="flex items-center gap-4">
                  <span class="w-6 h-[2px] rounded-full bg-cyan-600/40" />
                  <span class="text-cyan-400/50 text-xs tracking-[0.1em] font-light">
                    Udvalg {index + 1}
                  </span>
                </div>
                <h4 class="text-white text-xl sm:text-4xl lg:text-6xl font-light tracking-[0.02em] leading-tight">
                  {product.subName || product.name}
                </h4>
                <div class="w-12 h-[2px] rounded-full bg-cyan-500/15" />
              </div>

              <p class="text-cyan-100/50 text-sm sm:text-base leading-relaxed tracking-wide font-light max-w-sm">
                {product.description.length > 120
                  ? `${product.description.slice(0, 120).trim()}...`
                  : product.description}
              </p>

              <div class="flex items-baseline gap-8">
                <span class="text-white text-2xl font-light tracking-wide">
                  {product.price}
                </span>
                <a
                  href={`/product/${product.handle}`}
                  aria-label={`Se detaljer for ${product.name}`}
                  class="group/link inline-flex items-center gap-4 text-cyan-400/40 hover:text-cyan-100 transition-colors duration-300 text-sm tracking-[0.04em] font-light py-2 px-1 -my-2 touch-manipulation min-h-[44px]"
                >
                  Detaljer
                  <div class="w-10 h-[2px] rounded-full bg-cyan-500/10 group-hover/link:bg-cyan-400/50 group-hover/link:w-16 transition-all duration-400" />
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-20 sm:mt-32"></div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reduceMotion) {
    gsap.to(".archive-bg", {
      scrollTrigger: {
        trigger: "body",
        start: "top top",
        end: "12% top",
        scrub: true,
      },
      opacity: 1,
    });

    gsap.from(".archive-header > *", {
      scrollTrigger: {
        trigger: ".archive-header",
        start: "top 90%",
      },
      y: 50,
      opacity: 0,
      duration: 2,
      stagger: 0.2,
      ease: "expo.out",
    });
  } else {
    gsap.set(".archive-bg", { opacity: 1 });
  }

  // Make the whole product row behave like a card without fighting nested links.
  document.querySelectorAll("[data-product-card]").forEach((card) => {
    const link = card.querySelector<HTMLAnchorElement>("[data-product-card-link]");
    if (!link) return;

    card.addEventListener("click", (event) => {
      const target = event.target as HTMLElement;
      if (target.closest("a, button, input, select, textarea")) return;
      window.location.assign(link.href);
    });
  });

  if (!reduceMotion) {
    const rows = document.querySelectorAll(".product-row");
    rows.forEach((row) => {
      const visual = row.querySelector(".w-full.md\\:w-3\\/5");
      const content = row.querySelector(".w-full.md\\:w-2\\/5");

      gsap.from(visual, {
        scrollTrigger: {
          trigger: row,
          start: "top 80%",
        },
        opacity: 0,
        duration: 2.5,
        ease: "expo.out",
      });

      gsap.from(content, {
        scrollTrigger: {
          trigger: row,
          start: "top 70%",
        },
        opacity: 0,
        duration: 2.5,
        delay: 0.4,
        ease: "expo.out",
      });
    });
  }
</script>

<style>
  .product-row {
    will-change: transform, opacity;
  }

  @media (max-width: 767px) {
    .archive-bg {
      backdrop-filter: none;
    }
  }

  @media (hover: none) {
    .product-row img {
      transform: none !important;
    }

    .product-row img[class*="group-hover:opacity-0"] {
      opacity: 1 !important;
    }

    .product-row img[class*="group-hover:opacity-100"] {
      opacity: 0 !important;
    }
  }
</style>
