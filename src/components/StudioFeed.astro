---
const images = [
    "/collectionimg/_DSC8255.jpg",
    "/collectionimg/_DSC8260.jpg",
    "/collectionimg/_DSC8261.jpg",
    "/collectionimg/_DSC8264.jpg",
];
---

<section class="py-12 sm:py-20 md:py-32 bg-transparent relative z-20 overflow-hidden">
    <div class="container mx-auto px-4 sm:px-6">
        <div
            class="flex flex-col md:flex-row justify-between items-end gap-6 sm:gap-8 mb-12 sm:mb-16"
        >
            <div class="space-y-6">
                <div class="flex items-center gap-4">
                    <span class="w-6 h-[2px] rounded-full bg-cyan-700/40"></span>
                    <span
                        class="text-cyan-500/50 text-xs tracking-[0.08em] font-light"
                        >Visuals</span
                    >
                </div>
                <h2
                    class="text-white text-3xl sm:text-4xl md:text-6xl font-light tracking-[0.04em] leading-tight italic"
                >
                    Studio <br /> Perspective
                </h2>
            </div>

            <a
                href="https://instagram.com/boelgen.studio"
                target="_blank"
                class="group flex items-center gap-4 text-white/30 hover:text-white transition-colors duration-500 text-sm tracking-[0.04em] font-light"
            >
                Explore Instagram
                <div
                    class="w-10 h-[2px] rounded-full bg-white/10 group-hover:bg-cyan-400 group-hover:w-16 transition-all duration-700"
                >
                </div>
            </a>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 sm:gap-3 md:gap-4">
            {
                images.map((img, i) => (
                    <div
                        class={`feed-item aspect-square overflow-hidden bg-[#051117] rounded-xl sm:rounded-2xl group relative ${i % 2 === 1 ? "mt-4 sm:mt-8 md:mt-16" : ""}`}
                    >
                        <img
                            src={img}
                            alt="Studio Perspective"
                            class="w-full h-full object-cover opacity-40 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500 ease-out grayscale hover:grayscale-0"
                        />
                        <div class="absolute inset-0 bg-cyan-900/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
                    </div>
                ))
            }
        </div>
    </div>
</section>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    gsap.from(".feed-item", {
        scrollTrigger: {
            trigger: ".feed-item",
            start: "top 90%",
        },
        y: 60,
        opacity: 0,
        duration: 2,
        stagger: 0.2,
        ease: "expo.out",
    });
</script>
