---

---

<section
  class="hero-container fixed inset-0 w-full h-screen z-0 overflow-hidden"
>
  <div class="absolute inset-0 h-full w-full pointer-events-none">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="hero-media block w-full h-full object-cover"
      id="hero-video"
    >
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>

    <img
      src="/hero-2-Gv_c13hE.jpeg"
      alt="Ocean"
      class="hero-media hidden w-full h-full object-cover"
    />

    <div
      class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/40"
    >
    </div>
  </div>

  <div
    class="hero-content relative z-50 flex flex-col items-center justify-center h-full text-center px-4 sm:px-6 pb-[env(safe-area-inset-bottom)]"
  >
    <img
      src="/logo-bolgen.svg"
      alt="Bølgen"
      class="h-24 sm:h-32 md:h-48 mb-6 sm:mb-8 brightness-0 invert drop-shadow-[0_0_30px_rgba(255,255,255,0.4)]"
    />

    <h1
      class="text-white text-base sm:text-lg md:text-2xl font-light tracking-[0.06em] mb-8 sm:mb-12 flex flex-wrap items-center justify-center gap-x-2 sm:gap-x-4 gap-y-1"
    >
      Sommer <span class="text-white/30">·</span> Dybde <span class="text-white/30">·</span> Kulde
    </h1>

    <a
      href="#shop"
      class="group relative px-8 sm:px-12 py-3.5 sm:py-4 overflow-hidden border border-white/20 hover:border-white/50 transition-colors duration-500 rounded-full pointer-events-auto cursor-pointer backdrop-blur-sm touch-manipulation min-h-[44px] flex items-center justify-center"
    >
      <span
        class="relative z-10 text-white text-sm tracking-[0.04em] font-light group-hover:text-cyan-50 transition-colors"
        >Dyk ned</span
      >
      <div
        class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"
      >
      </div>
    </a>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.to(".hero-media", {
    scrollTrigger: {
      trigger: "body",
      start: "top top",
      end: "25% top",
      scrub: true,
    },
    filter: "blur(50px)",
    opacity: 0,
  });

  gsap.to(".hero-content", {
    scrollTrigger: {
      trigger: "body",
      start: "top top",
      end: "12% top",
      scrub: true,
    },
    opacity: 0,
  });
</script>
