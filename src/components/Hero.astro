---

---

<section
  class="hero-container fixed inset-0 w-full h-[100svh] z-0 overflow-hidden"
>
  <div class="hero-visual absolute inset-0 h-full w-full pointer-events-none bg-black">
    <video
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline="true"
      preload="auto"
      class="hero-video block w-full h-full object-cover"
      id="hero-video"
    >
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>

    <div
      class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/40"
    >
    </div>
  </div>

  <div
    class="hero-content relative z-50 flex flex-col items-center justify-center h-full text-center px-4 sm:px-6 pb-[max(1rem,env(safe-area-inset-bottom))]"
  >
    <img
      src="/logo-bolgen.svg"
      alt="Bølgen"
      class="h-20 sm:h-32 md:h-48 mb-5 sm:mb-8 brightness-0 invert drop-shadow-[0_0_30px_rgba(255,255,255,0.4)]"
    />

    <h1
      class="text-white text-xs sm:text-lg md:text-2xl font-light tracking-[0.06em] mb-6 sm:mb-12 flex flex-wrap items-center justify-center gap-x-2 sm:gap-x-4 gap-y-1 px-2"
    >
      Sommer <span class="text-white/30">·</span> Havet <span class="text-white/30">·</span> Venner
    </h1>

    <a
      href="#shop"
      class="group relative w-full max-w-[14rem] px-8 sm:px-12 py-3.5 sm:py-4 overflow-hidden border border-white/20 hover:border-white/50 transition-colors duration-500 rounded-full pointer-events-auto cursor-pointer backdrop-blur-sm touch-manipulation min-h-[44px] flex items-center justify-center"
    >
      <span
        class="relative z-10 text-white text-sm tracking-[0.04em] font-light group-hover:text-cyan-50 transition-colors"
        >Dyk ned</span
      >
      <div
        class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"
      >
      </div>
    </a>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const heroVideo = document.getElementById("hero-video") as HTMLVideoElement | null;
  if (heroVideo) {
    const markReady = () => heroVideo.classList.add("is-ready");
    heroVideo.addEventListener("loadeddata", markReady, { once: true });
    heroVideo.addEventListener("canplay", markReady, { once: true });
    heroVideo.addEventListener("playing", markReady, { once: true });
    if (heroVideo.readyState >= 2) markReady();
    heroVideo.play().catch(() => {});
  }

  ScrollTrigger.getById("hero-visual-fade")?.kill();
  ScrollTrigger.getById("hero-content-fade")?.kill();

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduceMotion) {
    gsap.to(".hero-visual", {
      scrollTrigger: {
        id: "hero-visual-fade",
        trigger: ".hero-container",
        start: "top top",
        end: "35% top",
        scrub: true,
      },
      yPercent: 8,
      scale: 1.05,
      opacity: 0,
      ease: "none",
    });

    gsap.to(".hero-content", {
      scrollTrigger: {
        id: "hero-content-fade",
        trigger: ".hero-container",
        start: "top top",
        end: "30% top",
        scrub: true,
      },
      opacity: 0,
      ease: "none",
    });
  }
</script>

<style>
  .hero-video {
    opacity: 0;
    transition: opacity 320ms ease;
    transform: translateZ(0);
    backface-visibility: hidden;
    will-change: opacity, transform;
  }

  .hero-video.is-ready {
    opacity: 1;
  }
</style>
