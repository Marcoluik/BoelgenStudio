---

---

<section
  class="hero-container fixed inset-0 w-full h-[100svh] z-0 overflow-hidden"
>
  <div class="hero-visual absolute inset-0 h-full w-full pointer-events-none">
    <img
      src="/hero-2-Gv_c13hE.jpeg"
      alt="Hav"
      class="hero-poster w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />

    <video
      autoplay
      muted
      loop
      playsinline
      webkit-playsinline="true"
      preload="metadata"
      poster="/hero-2-Gv_c13hE.jpeg"
      class="hero-video w-full h-full object-cover"
      id="hero-video"
    >
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>

    <div
      class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/40"
    >
    </div>
  </div>

  <div
    class="hero-content relative z-50 flex flex-col items-center justify-center h-full text-center px-4 sm:px-6 pb-[max(1rem,env(safe-area-inset-bottom))]"
  >
    <img
      src="/logo-bolgen.svg"
      alt="Bølgen"
      class="h-20 sm:h-32 md:h-48 mb-5 sm:mb-8 brightness-0 invert drop-shadow-[0_0_30px_rgba(255,255,255,0.4)]"
    />

    <h1
      class="text-white text-xs sm:text-lg md:text-2xl font-light tracking-[0.06em] mb-6 sm:mb-12 flex flex-wrap items-center justify-center gap-x-2 sm:gap-x-4 gap-y-1 px-2"
    >
      Sommer <span class="text-white/30">·</span> Havet <span class="text-white/30">·</span> Venner
    </h1>

    <a
      href="#shop"
      class="group relative w-full max-w-[14rem] px-8 sm:px-12 py-3.5 sm:py-4 overflow-hidden border border-white/20 hover:border-white/50 transition-colors duration-500 rounded-full pointer-events-auto cursor-pointer backdrop-blur-sm touch-manipulation min-h-[44px] flex items-center justify-center"
    >
      <span
        class="relative z-10 text-white text-sm tracking-[0.04em] font-light group-hover:text-cyan-50 transition-colors"
        >Dyk ned</span
      >
      <div
        class="absolute inset-0 bg-white/10 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"
      >
      </div>
    </a>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const heroContainer = document.querySelector<HTMLElement>(".hero-container");
  const heroVideo = document.getElementById("hero-video") as HTMLVideoElement | null;

  function showVideoIfPlayable() {
    if (!heroContainer || !heroVideo) return;
    let ready = false;

    const markReady = () => {
      if (ready) return;
      ready = true;
      heroContainer.classList.add("hero-video-ready");
    };

    const failToPoster = () => {
      if (ready) return;
      heroContainer.classList.add("hero-video-failed");
    };

    heroVideo.addEventListener("loadeddata", markReady, { once: true });
    heroVideo.addEventListener("canplay", markReady, { once: true });
    heroVideo.addEventListener("playing", markReady, { once: true });
    heroVideo.addEventListener("error", failToPoster, { once: true });
    heroVideo.addEventListener("stalled", failToPoster, { once: true });

    // If decoding/playback is blocked on production devices, keep poster visible.
    window.setTimeout(() => {
      if (!ready && heroVideo.readyState < 2) failToPoster();
    }, 3000);

    const playPromise = heroVideo.play();
    if (playPromise && typeof playPromise.catch === "function") {
      playPromise.catch(() => failToPoster());
    }

    if (heroVideo.readyState >= 2) {
      markReady();
    }
  }

  showVideoIfPlayable();

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduceMotion) {
    const isMobile = window.matchMedia("(max-width: 767px)").matches;

    gsap.to(".hero-visual", {
      scrollTrigger: {
        trigger: ".hero-container",
        start: "top top",
        end: "35% top",
        scrub: true,
      },
      filter: isMobile ? "blur(12px)" : "blur(50px)",
      opacity: 0,
    });

    gsap.to(".hero-content", {
      scrollTrigger: {
        trigger: "body",
        start: "top top",
        end: "12% top",
        scrub: true,
      },
      opacity: 0,
    });
  }
</script>

<style>
  .hero-poster,
  .hero-video {
    position: absolute;
    inset: 0;
  }

  .hero-video {
    opacity: 0;
    transition: opacity 500ms ease;
    will-change: opacity;
  }

  .hero-container.hero-video-ready .hero-video {
    opacity: 1;
  }

  .hero-container.hero-video-failed .hero-video {
    display: none;
  }
</style>
