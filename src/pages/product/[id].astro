---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import { getProductsAtBuild } from "../../lib/fetch-products";

export async function getStaticPaths() {
    const products = await getProductsAtBuild();
    return products.map((product) => ({
        params: { id: product.handle },
        props: {
            product,
            otherProducts: products.filter((p) => p.handle !== product.handle),
        },
    }));
}

const { product, otherProducts } = Astro.props;
const availableCount = product.variants.filter((v) => v.availableForSale).length;
const totalVariants = product.variants.length;
const isSoldOut = totalVariants > 0 && availableCount === 0;
const isLimited = availableCount > 0 && availableCount < totalVariants;
const hasVariants = totalVariants > 0;
---

<Layout title={`${product.name} | ${product.subName}`}>
    <Navigation />

    {/* Fixed Oceanic Background */}
    <div class="fixed inset-0 pointer-events-none z-0 bg-[#000d12]">
        <div
            class="absolute top-[-10%] left-[20%] w-[60%] h-[60%] bg-cyan-400/5 blur-[150px] rounded-full"
        >
        </div>
        <div
            class="absolute bottom-[20%] right-[10%] w-[50%] h-[50%] bg-blue-300/5 blur-[120px] rounded-full"
        >
        </div>
    </div>

    <main class="relative z-10 min-h-screen pt-20 sm:pt-24 pb-16 sm:pb-24">
        <div class="container mx-auto px-4 sm:px-6 max-w-6xl">
            {/* Back to Archive Link */}
            <div class="mb-12">
                <a
                    href="/#shop"
                    class="group inline-flex items-center gap-4 py-2 -my-2 text-cyan-100/30 hover:text-cyan-100 transition-colors duration-500 text-sm tracking-[0.04em] font-light touch-manipulation"
                >
                    <svg
                        width="24"
                        height="1"
                        viewBox="0 0 24 1"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-6 rotate-180 opacity-40 group-hover:opacity-100 group-hover:translate-x-[-4px] transition-all duration-500"
                    >
                        <line y1="0.5" x2="24" y2="0.5" stroke="currentColor"
                        ></line>
                    </svg>
                    Back to Collection
                </a>
            </div>

            <div
                class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-20 items-start"
            >
                {/* Gallery Section */}
                <div class="space-y-6">
                    <div
                        class="gallery-main aspect-[3/4] max-h-[70vh] min-h-[280px] overflow-hidden bg-[#051117] group rounded-2xl border border-white/5 relative"
                    >
                        <img
                            src={product.mainImage}
                            alt={product.name}
                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                            id="main-image"
                        />
                        {/* Left nav zone - prev: always visible on mobile (no hover), hover-reveal on desktop */}
                        <button
                            type="button"
                            class="gallery-prev absolute left-0 top-0 bottom-0 w-1/4 min-w-[60px] flex items-center justify-start pl-2 sm:pl-4 cursor-pointer z-20 opacity-100 md:opacity-0 md:group-hover:opacity-100 hover:bg-white/5 transition-opacity duration-300 touch-manipulation"
                            aria-label="Previous image"
                        >
                            <span class="flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-black/30 md:bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm">
                                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7" />
                                </svg>
                            </span>
                        </button>
                        {/* Right nav zone - next */}
                        <button
                            type="button"
                            class="gallery-next absolute right-0 top-0 bottom-0 w-1/4 min-w-[60px] flex items-center justify-end pr-2 sm:pr-4 cursor-pointer z-20 opacity-100 md:opacity-0 md:group-hover:opacity-100 hover:bg-white/5 transition-opacity duration-300 touch-manipulation"
                            aria-label="Next image"
                        >
                            <span class="flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-black/30 md:bg-white/10 hover:bg-white/20 transition-colors backdrop-blur-sm">
                                <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
                                </svg>
                            </span>
                        </button>
                    </div>

                    <div class="grid grid-cols-3 gap-2 sm:gap-3 md:gap-4">
                        <div
                            class="aspect-[3/4] overflow-hidden bg-[#051117] group cursor-pointer thumbnail border border-white/5 rounded-xl"
                        >
                            <img
                                src={product.mainImage}
                                alt={`${product.name} front detail`}
                                class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-400"
                            />
                        </div>
                        {
                            product.gallery.map((img) => (
                                <div class="aspect-[3/4] overflow-hidden bg-[#051117] group cursor-pointer thumbnail border border-white/5 rounded-xl">
                                    <img
                                        src={img}
                                        alt={`${product.name} detail`}
                                        class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-400"
                                    />
                                </div>
                            ))
                        }
                        <div
                            class="aspect-[3/4] overflow-hidden bg-[#051117] group cursor-pointer thumbnail border border-white/5 rounded-xl"
                        >
                            <img
                                src={product.backImage}
                                alt={`${product.name} back view`}
                                class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-all duration-400"
                            />
                        </div>
                    </div>
                </div>

                {/* Info Section */}
                <div class="lg:sticky lg:top-40 space-y-12 product-info relative z-10">
                    <div>
                        <div class="flex items-center gap-4 mb-6">
                            <span class="w-6 h-[2px] rounded-full bg-cyan-700/50"></span>
                            <span
                                class="text-cyan-500/50 text-xs tracking-[0.08em] font-light"
                                >Selection detail</span
                            >
                        </div>
                        <h1
                            class="text-white text-3xl sm:text-4xl lg:text-6xl font-light tracking-[0.02em] mb-4 leading-tight"
                        >
                            {product.name}
                        </h1>
                        <p
                            class="text-white/40 text-base tracking-[0.04em] mb-8 font-light"
                        >
                            {product.subName}
                        </p>

                        {/* Stock Marker - uses real availability from Shopify */}
                        {hasVariants && (
                            <div
                                class={`flex items-center gap-3 py-2 px-4 rounded-full w-fit border ${
                                    isSoldOut ? "bg-red-950/20 border-red-900/20" : isLimited ? "bg-amber-950/20 border-amber-900/20" : "bg-emerald-950/20 border-emerald-900/20"
                                }`}
                            >
                                <span
                                    class={`w-1.5 h-1.5 rounded-full ${isSoldOut ? "bg-red-500 animate-pulse" : isLimited ? "bg-amber-500" : "bg-emerald-500"}`}
                                ></span>
                                <span
                                    class={`text-xs tracking-[0.04em] font-light ${isSoldOut ? "text-red-400" : isLimited ? "text-amber-400" : "text-emerald-400"}`}
                                >
                                    {isSoldOut ? "Sold out" : isLimited ? `${availableCount} of ${totalVariants} sizes available` : "In stock"}
                                </span>
                            </div>
                        )}
                    </div>

                    <div class="space-y-6">
                        <p
                            class="text-white/80 text-base leading-relaxed font-light tracking-wide max-w-md"
                        >
                            {product.description}
                        </p>
                        <p
                            class="text-white text-3xl font-light tracking-wide mt-8"
                        >
                            {product.price}
                        </p>
                    </div>

                    <div class="space-y-10 relative z-10">
                        <div class="space-y-4">
                            <div
                                class="flex justify-between items-end max-w-xs"
                            >
                                <span
                                    class="text-white/50 text-[10px] tracking-[0.08em] block font-light"
                                >
                                    Select Size
                                </span>
                                <button
                                    class="size-guide-trigger text-cyan-400/60 hover:text-cyan-400 text-sm tracking-[0.04em] font-light transition-colors border-b border-cyan-500/20"
                                    >Size Guide</button
                                >
                            </div>

                            {/* Size Guide Modal */}
                            <div
                                id="size-guide-modal"
                                class="fixed inset-0 z-[110] flex items-center justify-center p-4 sm:p-6 invisible pointer-events-none"
                            >
                                <div
                                    class="absolute inset-0 bg-black/80 backdrop-blur-md opacity-0 transition-opacity duration-500 modal-backdrop"
                                >
                                </div>
                                <div
                                    class="relative bg-[#001c25] border border-white/5 rounded-2xl p-6 sm:p-8 md:p-12 max-w-2xl w-full max-h-[90vh] overflow-y-auto translate-y-10 opacity-0 transition-all duration-700 modal-content"
                                >
                                    <button
                                        class="absolute top-6 right-6 text-white/20 hover:text-white transition-colors close-modal text-sm tracking-wide font-light"
                                        >Close</button
                                    >

                                    <div class="space-y-12">
                                        <div class="space-y-4">
                                            <h3
                                                class="text-white text-3xl font-light tracking-wide italic"
                                            >
                                                Size Guide
                                            </h3>
                                            <div
                                                class="w-10 h-[2px] rounded-full bg-cyan-500/20"
                                            >
                                            </div>
                                        </div>

                                        <div class="overflow-x-auto">
                                            <table
                                                class="w-full text-left border-collapse"
                                            >
                                                <thead>
                                                    <tr
                                                        class="border-b border-white/10"
                                                    >
                                                        <th
                                                            class="py-4 text-white/40 text-[10px] tracking-[0.06em]  font-light"
                                                            >Size</th
                                                        >
                                                        <th
                                                            class="py-4 text-white/40 text-[10px] tracking-[0.06em]  font-light"
                                                            >Chest (cm)</th
                                                        >
                                                        <th
                                                            class="py-4 text-white/40 text-[10px] tracking-[0.06em]  font-light"
                                                            >Length (cm)</th
                                                        >
                                                        <th
                                                            class="py-4 text-white/40 text-[10px] tracking-[0.06em]  font-light"
                                                            >Sleeve (cm)</th
                                                        >
                                                    </tr>
                                                </thead>
                                                <tbody
                                                    class="text-[11px] tracking-wide "
                                                >
                                                    <tr
                                                        class="border-b border-white/5"
                                                    >
                                                        <td
                                                            class="py-6 text-white"
                                                            >S</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >56</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >68</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >63</td
                                                        >
                                                    </tr>
                                                    <tr
                                                        class="border-b border-white/5"
                                                    >
                                                        <td
                                                            class="py-6 text-white"
                                                            >M</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >59</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >71</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >65</td
                                                        >
                                                    </tr>
                                                    <tr
                                                        class="border-b border-white/5"
                                                    >
                                                        <td
                                                            class="py-6 text-white"
                                                            >L</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >62</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >74</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >67</td
                                                        >
                                                    </tr>
                                                    <tr>
                                                        <td
                                                            class="py-6 text-white"
                                                            >XL</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >65</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >77</td
                                                        >
                                                        <td
                                                            class="py-6 text-white/60"
                                                            >69</td
                                                        >
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>

                                        {/* Fit Guide */}
                                        <div class="space-y-4 pt-6 border-t border-white/10">
                                            <h4 class="text-white/70 text-sm tracking-[0.06em] font-light">Fit Guide</h4>
                                            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                                                <div class="py-3 px-4 rounded-xl bg-white/5 border border-white/5">
                                                    <span class="block text-white/40 text-[10px] tracking-[0.06em] mb-1">S</span>
                                                    <span class="text-white/80 text-xs">Size up</span>
                                                </div>
                                                <div class="py-3 px-4 rounded-xl bg-white/5 border border-white/5">
                                                    <span class="block text-white/40 text-[10px] tracking-[0.06em] mb-1">M</span>
                                                    <span class="text-white/80 text-xs">Regular</span>
                                                </div>
                                                <div class="py-3 px-4 rounded-xl bg-white/5 border border-white/5">
                                                    <span class="block text-white/40 text-[10px] tracking-[0.06em] mb-1">L</span>
                                                    <span class="text-white/80 text-xs">Regular</span>
                                                </div>
                                                <div class="py-3 px-4 rounded-xl bg-white/5 border border-white/5">
                                                    <span class="block text-white/40 text-[10px] tracking-[0.06em] mb-1">XL</span>
                                                    <span class="text-white/80 text-xs">Size down</span>
                                                </div>
                                            </div>
                                            <p class="text-white/40 text-xs leading-relaxed">
                                                Relaxed, cinematic fit. Between sizes? Size up for an oversized look.
                                            </p>
                                        </div>

                                        <p
                                            class="text-white/30 text-[9px] tracking-wide leading-relaxed  italic"
                                        >
                                            * All measurements are taken flat.
                                            Our pieces are designed for a
                                            relaxed, cinematic fit.
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="flex gap-3 sm:gap-4 flex-wrap" id="size-buttons-container">
                                {
                                    product.variants.length > 0 ? (
                                        product.variants.map((v) => (
                                            <button
                                                type="button"
                                                class={`size-btn w-12 h-12 min-w-[48px] min-h-[48px] border border-white/10 text-[10px] tracking-wide transition-all duration-500 rounded-xl bg-white/[0.02] touch-manipulation cursor-pointer select-none ${v.availableForSale ? "text-white/40 hover:border-cyan-500/60 hover:text-white active:scale-95" : "text-white/20 opacity-50 line-through"}`}
                                                data-variant-id={v.id}
                                                data-variant-title={v.title}
                                                data-available={String(v.availableForSale)}
                                                tabindex="0"
                                            >
                                                {v.title}
                                            </button>
                                        ))
                                    ) : (
                                        <p class="text-white/40 text-sm font-light italic">No sizes available</p>
                                    )
                                }
                            </div>
                        </div>

                        <div class="space-y-4">
                            <button
                                class="add-to-cart-btn w-full py-5 sm:py-6 min-h-[48px] border border-white/20 rounded-2xl text-white text-sm tracking-[0.04em] font-light relative group overflow-hidden transition-all duration-500 hover:border-cyan-400/40 touch-manipulation disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:border-white/20"
                                disabled={product.variants.length === 0}
                            >
                                <div
                                    class="absolute inset-0 bg-white/[0.03] group-hover:bg-cyan-400/10 transition-colors duration-500"
                                >
                                </div>
                                <span class="relative z-10 font-light"
                                    >Add to Collection</span
                                >
                                <div
                                    class="absolute bottom-0 left-0 w-0 h-[1px] bg-cyan-400/60 group-hover:w-full transition-all duration-500"
                                >
                                </div>
                            </button>
                            <p
                                class="text-xs text-white/40 tracking-[0.04em] font-light text-center italic"
                            >
                                Includes free studio-exclusive packaging
                            </p>

                            {/* Trust Bar */}
                            <div
                                class="pt-6 flex flex-wrap justify-center items-center gap-4 sm:gap-8 opacity-20 group-hover:opacity-40 transition-opacity duration-500"
                            >
                                <div class="flex items-center gap-2">
                                    <svg
                                        class="w-3 h-3"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="1.5"
                                            d="M5 13l4 4L19 7"></path></svg
                                    >
                                    <span
                                        class="text-[8px] tracking-[0.06em] "
                                        >Global Priority</span
                                    >
                                </div>
                                <div class="flex items-center gap-2">
                                    <svg
                                        class="w-3 h-3"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="1.5"
                                            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 00-2 2zm10-10V7a4 4 0 00-8 0v4h8z"
                                        ></path></svg
                                    >
                                    <span
                                        class="text-[8px] tracking-[0.06em] "
                                        >Secure Collection</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="pt-12 space-y-0">
                        <div
                            class="accordion group border-t border-white/15 overflow-hidden"
                        >
                            <button
                                type="button"
                                class="accordion-trigger w-full flex justify-between items-center py-5 sm:py-6 min-h-[48px] cursor-pointer text-left bg-transparent border-none touch-manipulation"
                            >
                                <span
                                    class="text-white/80 text-xs tracking-[0.1em] font-light"
                                    >Specifications</span
                                >
                                <span
                                    class="accordion-icon text-white/40 transition-transform duration-300"
                                    >+</span
                                >
                            </button>
                            <div class="accordion-content">
                                <div class="pb-8 space-y-4">
                                <p
                                    class="text-white/60 text-sm leading-relaxed font-light tracking-wide"
                                >
                                    Heavy-weight 450GSM cotton. Custom
                                    silhouette designed in our studio. Features
                                    high-density screen printing and reinforced
                                    stitching.
                                </p>
                                <div class="grid grid-cols-2 gap-4 pt-4">
                                    <div>
                                        <span
                                            class="block text-xs text-white/40 tracking-wide mb-1"
                                            >Fabric</span
                                        >
                                        <span
                                            class="text-sm text-white/80 tracking-wide"
                                            >100% Organic Cotton</span
                                        >
                                    </div>
                                    <div>
                                        <span
                                            class="block text-xs text-white/40 tracking-wide mb-1"
                                            >Origin</span
                                        >
                                        <span
                                            class="text-sm text-white/80 tracking-wide"
                                            >Made in Portugal</span
                                        >
                                    </div>
                                </div>
                                </div>
                            </div>
                        </div>

                        <div
                            class="accordion group border-t border-white/15 overflow-hidden"
                        >
                            <button
                                type="button"
                                class="accordion-trigger w-full flex justify-between items-center py-5 sm:py-6 min-h-[48px] cursor-pointer text-left bg-transparent border-none touch-manipulation"
                            >
                                <span
                                    class="text-white/80 text-xs tracking-[0.1em] font-light"
                                    >Shipping & Returns</span
                                >
                                <span
                                    class="accordion-icon text-white/40 transition-transform duration-300"
                                    >+</span
                                >
                            </button>
                            <div class="accordion-content">
                                <div class="pb-8">
                                <p
                                    class="text-white/60 text-sm leading-relaxed font-light tracking-wide"
                                >
                                    Global shipping available. Standard delivery
                                    2-4 business days within EU. 14-day return
                                    period on all Collection pieces.
                                </p>
                                </div>
                            </div>
                        </div>

                        <div class="pt-8 border-t border-white/15 flex gap-8">
                            <div class="flex flex-col gap-1">
                                <span
                                    class="text-xs text-cyan-500/60 tracking-[0.08em]"
                                    >Status</span
                                >
                                <span
                                    class="text-sm text-white/80 tracking-[0.06em]"
                                    >Live Collection</span
                                >
                            </div>
                            <div class="flex flex-col gap-1">
                                <span
                                    class="text-xs text-cyan-500/60 tracking-[0.08em]"
                                    >Studio</span
                                >
                                <span
                                    class="text-sm text-white/80 tracking-[0.06em]"
                                    >Copenhagen</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {/* Other Pieces Section */}
            {
                otherProducts.length > 0 && (
                    <div class="mt-32">
                        <div class="flex items-center gap-6 mb-16">
                            <div class="h-[2px] w-10 rounded-full bg-cyan-500/20" />
                            <h2 class="text-white/40 text-sm tracking-[0.08em] font-light">
                                Continue Exploring
                            </h2>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-12">
                            {otherProducts.map((p) => (
                                <a
                                    href={`/product/${p.handle}`}
                                    class="group relative block overflow-hidden"
                                >
                                    <div class="aspect-[16/9] overflow-hidden bg-[#051117] rounded-2xl border border-white/5 relative">
                                        <img
                                            src={p.mainImage}
                                            alt={p.name}
                                            class="w-full h-full object-cover opacity-60 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500 ease-out"
                                        />
                                        <div class="absolute inset-x-4 sm:inset-x-8 bottom-4 sm:bottom-8 flex justify-between items-end z-20">
                                            <div>
                                                <span class="text-xs text-cyan-400/60 tracking-[0.06em] block mb-2 font-light">
                                                    {p.subName}
                                                </span>
                                                <h3 class="text-white text-2xl font-light tracking-wide">
                                                    {p.name}
                                                </h3>
                                            </div>
                                            <span class="text-white/40 text-sm tracking-wide mb-1 underline underline-offset-8 font-light">
                                                Explore
                                            </span>
                                        </div>
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60" />
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>
    </main>
</Layout>

<script>
    import gsap from "gsap";

    // Initial animation
    gsap.from(".product-info > *", {
        y: 30,
        opacity: 0,
        duration: 2,
        stagger: 0.15,
        ease: "expo.out",
        delay: 0.3,
    });

    // Gallery: build ordered image list from thumbnails
    const mainImg = document.getElementById("main-image") as HTMLImageElement;
    const thumbnails = document.querySelectorAll(".thumbnail img");
    const imageUrls = Array.from(thumbnails).map((img) => (img as HTMLImageElement).src);
    let currentIndex = 0;

    function showImage(index: number) {
        if (imageUrls.length === 0) return;
        currentIndex = ((index % imageUrls.length) + imageUrls.length) % imageUrls.length;
        const newSrc = imageUrls[currentIndex];
        if (mainImg.src === newSrc) return;
        gsap.to(mainImg, {
            opacity: 0,
            scale: 0.98,
            duration: 0.35,
            ease: "power2.inOut",
            onComplete: () => {
                mainImg.src = newSrc;
                gsap.to(mainImg, {
                    opacity: 1,
                    scale: 1,
                    duration: 0.5,
                    ease: "expo.out",
                });
            },
        });
        // Sync thumbnail active state
        thumbnails.forEach((t, i) => {
            const el = t.closest(".thumbnail");
            if (el) {
                el.classList.toggle("ring-2", i === currentIndex);
                el.classList.toggle("ring-cyan-400/60", i === currentIndex);
            }
        });
    }

    document.querySelector(".gallery-prev")?.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        showImage(currentIndex - 1);
    });
    document.querySelector(".gallery-next")?.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        showImage(currentIndex + 1);
    });

    thumbnails.forEach((thumb, i) => {
        thumb.closest(".thumbnail")?.addEventListener("click", () => {
            showImage(i);
        });
    });

    // Initial thumbnail active state
    thumbnails.forEach((t, i) => {
        const el = t.closest(".thumbnail");
        if (el) {
            el.classList.toggle("ring-2", i === 0);
            el.classList.toggle("ring-cyan-400/60", i === 0);
        }
    });

    // Size button selection - use data-selected for reliable styling (avoids Tailwind class conflicts)
    const sizeContainer = document.getElementById("size-buttons-container");
    sizeContainer?.addEventListener("click", (e) => {
        const btn = (e.target as Element).closest<HTMLButtonElement>(".size-btn");
        if (!btn) return;
        document.querySelectorAll(".size-btn").forEach((b) => b.removeAttribute("data-selected"));
        btn.setAttribute("data-selected", "true");
    });

    // Default select first available variant on load
    const firstAvailable = document.querySelector<HTMLButtonElement>(".size-btn[data-available='true']") ?? document.querySelector<HTMLButtonElement>(".size-btn");
    if (firstAvailable) {
        firstAvailable.setAttribute("data-selected", "true");
    }

    // Add to Collection: add variant to Shopify cart
    const addToCartBtn = document.querySelector<HTMLButtonElement>(".add-to-cart-btn");
    addToCartBtn?.addEventListener("click", async () => {
        const selectedSizeBtn = document.querySelector<HTMLButtonElement>(".size-btn[data-selected='true']");
        const variantId = selectedSizeBtn?.dataset.variantId;
        const isAvailable = selectedSizeBtn?.dataset.available === "true";

        if (!variantId) {
            alert("Vælg venligst en størrelse.");
            return;
        }
        if (!isAvailable) {
            alert("Denne størrelse er udsolgt.");
            return;
        }

        addToCartBtn.disabled = true;
        const originalText = addToCartBtn.querySelector("span")?.textContent ?? "Add to Collection";
        addToCartBtn.querySelector("span")!.textContent = "Adding...";

        try {
            const { addVariantToCart } = await import("../../lib/cart-client");
            await addVariantToCart(variantId, 1);
            if ((window as any).openCart) (window as any).openCart();
        } catch (err) {
            console.error("Add to cart failed:", err);
            alert("Kunne ikke tilføje til kurv. Prøv igen.");
        } finally {
            addToCartBtn.disabled = false;
            addToCartBtn.querySelector("span")!.textContent = originalText;
        }
    });

    // Size Guide Modal Logic
    const sizeGuideTrigger = document.querySelector(".size-guide-trigger");
    const modal = document.getElementById("size-guide-modal");
    const modalBackdrop = modal?.querySelector(".modal-backdrop");
    const modalContent = modal?.querySelector(".modal-content");
    const closeModal = modal?.querySelector(".close-modal");

    const openModal = () => {
        if (!modal || !modalBackdrop || !modalContent) return;
        modal.classList.remove("invisible", "pointer-events-none");
        modal.classList.add("modal-open");
        document.body.style.overflow = "hidden";
        document.body.style.touchAction = "none";
        gsap.to(modalBackdrop, { opacity: 1, duration: 0.5 });
        gsap.to(modalContent, {
            opacity: 1,
            y: 0,
            duration: 0.8,
            ease: "expo.out",
        });
    };

    const hideModal = () => {
        if (!modal || !modalBackdrop || !modalContent) return;
        gsap.to(modalContent, { opacity: 0, y: 20, duration: 0.5 });
        gsap.to(modalBackdrop, {
            opacity: 0,
            duration: 0.5,
            onComplete: () => {
                modal.classList.add("invisible", "pointer-events-none");
                modal.classList.remove("modal-open");
                document.body.style.overflow = "";
                document.body.style.touchAction = "";
            },
        });
    };

    sizeGuideTrigger?.addEventListener("click", openModal);
    closeModal?.addEventListener("click", hideModal);
    modalBackdrop?.addEventListener("click", hideModal);

    // Accordion toggle - use event delegation so it works with View Transitions
    document.addEventListener("click", (e) => {
        const trigger = (e.target as Element).closest(".accordion-trigger");
        if (trigger) {
            e.preventDefault();
            const accordion = trigger.closest(".accordion");
            accordion?.classList.toggle("open");
        }
    });
</script>

<style>
    /* Prevent layout shift during image switch */
    #main-image {
        will-change: opacity, transform;
    }

    summary::-webkit-details-marker {
        display: none;
    }

    /* Smooth accordion expand/collapse */
    .accordion-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s ease;
    }

    .accordion.open .accordion-content {
        max-height: min(400px, 60vh);
    }

    .accordion.open .accordion-icon {
        transform: rotate(45deg);
    }

    /* Size buttons - ensure clickable and good touch targets */
    #size-buttons-container .size-btn {
        pointer-events: auto;
        -webkit-tap-highlight-color: transparent;
    }

    /* Selected state - explicit CSS so it always sticks (avoids Tailwind class order issues) */
    #size-buttons-container .size-btn[data-selected="true"] {
        border-color: rgb(6 182 212);
        color: rgb(255 255 255);
    }
</style>
