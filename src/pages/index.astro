---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Hero from "../components/Hero.astro";
import Collection from "../components/Collection.astro";
import StudioFeed from "../components/StudioFeed.astro";
import { getHomepageProductsAtBuild } from "../lib/fetch-products";

const products = await getHomepageProductsAtBuild();
---

<Layout title="Bølgen | Studio" preloadImage="/hero-2-Gv_c13hE.jpeg">
  <Navigation />

  <main class="relative z-10">
    <Hero />
    <Collection products={products} />
    <StudioFeed />
  </main>
</Layout>

<style>
  /* Hide scrollbar for cleaner look if needed */
  ::-webkit-scrollbar {
    width: 0px;
    background: transparent;
  }
</style>
