# Shopify Storefront API (public token - safe for client-side)
# 1. Shopify Admin > Settings > Apps and sales channels > Develop apps
# 2. Create app > Configure Storefront API scopes (unauthenticated_read_product_listings, unauthenticated_write_checkouts, etc.)
# 3. Install app > Copy Storefront API access token
#
# ANBEFALET OPSAETNING FOR BOELGENSTUDIO
# Frontend/site:
#   bolgenstudio.com            -> Netlify
# Checkout:
#   shop.bolgenstudio.com       -> shops.myshopify.com
# Shopify API domain:
#   boelgenstudio.myshopify.com
#
# DNS kan derfor vaere:
#   A      @        75.2.60.5                  (Netlify)
#   CNAME  www      boelgenstudio.netlify.app (Netlify)
#   CNAME  shop     shops.myshopify.com       (Shopify)
#   CNAME  account  shops.myshopify.com       (Shopify)
#
# I Shopify -> Settings -> Domains:
#   - forbind shop.bolgenstudio.com
#   - sæt shop.bolgenstudio.com som Primary domain
#   - lad bolgenstudio.com blive paa Netlify
#   - lad IKKE bolgenstudio.com vaere Shopify primary
#
# Storefront API skal stadig bruge myshopify-domænet:
PUBLIC_SHOPIFY_STORE_DOMAIN=boelgenstudio.myshopify.com
PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
#
# Checkout skal eksplicit bruge Shopify-checkout-domænet:
PUBLIC_SHOPIFY_CHECKOUT_ORIGIN=https://shop.bolgenstudio.com

# Contact + nyhedsbrev: modtageradresse (FormSubmit — gratis, første besked aktiverer formularen).
# Hvis tom: Netlify Forms (kun hvis siden hostes på Netlify).
PUBLIC_CONTACT_EMAIL=
